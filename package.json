{
  "name": "@mustafaj/capacitor-plugin-playlist",
  "version": "0.9.9",
  "description": "Capacitor audio playlist plugin with Android, iOS, and web support",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "dist/",
    "CHANGELOG.md",
    "Package.swift",
    "ios/",
    "android/",
    "MustafajCapacitorPluginPlaylist.podspec"
  ],
  "scripts": {
    "verify": "pnpm run verify:ios && pnpm run verify:android && pnpm run verify:web",
    "verify:ios": "cd ios && pod install && xcodebuild -workspace Plugin.xcworkspace -scheme Plugin && cd ..",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "pnpm run build",
    "lint": "pnpm run eslint && pnpm run prettier --check && pnpm run swiftlint lint",
    "fmt": "pnpm run eslint --fix && pnpm run prettier --write && pnpm run swiftlint autocorrect --format",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api PlaylistPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "pnpm run clean && pnpm run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "pnpm run build",
    "prepare": "pnpm run build"
  },
  "author": "mustafa j",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/docgen": "^0.3.1",
    "@capacitor/ios": "^8.0.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@ionic/eslint-config": "^0.4.0",
    "@types/hls.js": "^0.13.2",
    "eslint": "^8.57.1",
    "prettier": "^3.6.2",
    "prettier-plugin-java": "^2.7.7",
    "rimraf": "^6.1.0",
    "rollup": "^4.53.2",
    "swiftlint": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native"
  ],
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mustafa0x/capacitor-plugin-playlist.git"
  },
  "bugs": {
    "url": "https://github.com/mustafa0x/capacitor-plugin-playlist/issues"
  },
  "homepage": "https://github.com/mustafa0x/capacitor-plugin-playlist#readme",
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "@types/node": "^20.0.0"
  }
}
